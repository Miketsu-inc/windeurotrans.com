---
import { useTranslation } from "../i18n/utils";

const { locale } = Astro.props;

const year = new Date().getFullYear();

const t = useTranslation(locale);
---

<footer
  class="border-t border-white/5 bg-secondary px-6 pt-24 pb-8 text-white
        md:px-12"
>
  <div class="mx-auto mb-16 grid max-w-7xl grid-cols-1 gap-12 md:grid-cols-4">
    <div class="md:col-span-1">
      <img
        src={`${import.meta.env.BASE_URL}/logo.png`}
        class="size-16 w-full object-contain"
      />
    </div>
    <div>
      <h4 class="mb-6 text-lg font-bold">{t("footer.company.name")}</h4>
      <ul class="space-y-4 text-sm text-gray-200">
        <li>
          <a href="#" class="hover:text-primary transition-all hover:pl-2"
            >{t("footer.company.about")}</a
          >
        </li>
        <li>
          <a href="#" class="hover:text-primary transition-all hover:pl-2"
            >{t("footer.company.employees")}</a
          >
        </li>
        <li>
          <a href="#" class="hover:text-primary transition-all hover:pl-2"
            >{t("footer.company.contact")}</a
          >
        </li>
      </ul>
    </div>
    <div>
      <h4 class="mb-6 text-lg font-bold">{t("footer.services.name")}</h4>
      <ul class="space-y-4 text-sm text-gray-200">
        <li>
          <a href="#" class="hover:text-primary transition-all hover:pl-2"
            >{t("footer.services.shipping")}</a
          >
        </li>
        <li>
          <a href="#" class="hover:text-primary transition-all hover:pl-2"
            >{t("footer.services.dispatch")}</a
          >
        </li>
        <li>
          <a href="#" class="hover:text-primary transition-all hover:pl-2"
            >{t("footer.services.forwarding")}</a
          >
        </li>
        <li>
          <a href="#" class="hover:text-primary transition-all hover:pl-2"
            >{t("footer.services.customs")}</a
          >
        </li>
      </ul>
    </div>
    <div>
      <h4 class="mb-6 text-lg font-bold">{t("footer.contact.name")}</h4>
      <ul class="space-y-4 text-sm text-gray-200">
        <li>2120 Dunakeszi, Kolozsvár u. 29{t("footer.contact.country")}</li>
        <li>
          <a href="mailto:gergo.szell@windeurotrans.com"
            >gergo.szell@windeurotrans.com</a
          >
        </li>
        <li><a href="tel:+36205154060">+36 20 515 4060</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-white/20 pt-8 text-center text-xs text-gray-200">
    &copy; {year} Windeurotrans Kft. {t("footer.copyright")}.
  </div>
</footer>
